{
    "name": "meadow-integration",
    "version": "1.0.32",
    "description": "Meadow Data Integration",
    "bin": {
        "mdwint": "source/cli/Meadow-Integration-CLI-Run.js"
    },
    "main": "source/Meadow-Integration.js",
    "browser": "source/Meadow-Integration-Browser.js",
    "scripts": {
        "test": "npx quack test",
        "start": "node source/cli/Meadow-Integration-CLI-Run.js",
        "tests": "npx quack test -g",
        "coverage": "npx quack coverage",
        "build": "npx quack build"
    },
    "author": "steven velozo <steven@velozo.com>",
    "license": "MIT",
    "devDependencies": {
        "meadow-connection-sqlite": "^1.0.18",
        "pict-docuserve": "^0.1.5",
        "quackage": "^1.1.0"
    },
    "mocha": {
        "diff": true,
        "extension": [
            "js"
        ],
        "package": "./package.json",
        "reporter": "spec",
        "slow": "75",
        "timeout": "5000",
        "ui": "tdd",
        "watch-files": [
            "source/**/*.js",
            "test/**/*.js"
        ],
        "watch-ignore": [
            "lib/vendor"
        ]
    },
    "dependencies": {
        "fable": "^3.1.70",
        "fable-serviceproviderbase": "^3.0.19",
        "fast-xml-parser": "^4.4.1",
        "meadow": "^2.0.35",
        "meadow-connection-mssql": "^1.0.19",
        "meadow-connection-mysql": "^1.0.17",
        "orator": "^6.0.4",
        "orator-serviceserver-restify": "^2.0.10",
        "pict-section-flow": "^0.0.17",
        "pict-service-commandlineutility": "^1.0.19",
        "pict-sessionmanager": "^1.0.2",
        "pict-view": "^1.0.68",
        "xlsx": "^0.18.5"
    }
}
